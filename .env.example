# ─────────────────────────────────────────────
# HAVILON FLEET PORTAL — Environment Variables
# Copy this to .env and fill in your values
# ─────────────────────────────────────────────

# ── Database (Railway PostgreSQL) ─────────────
# Get this from: railway.app → New Project → PostgreSQL → Connect
DATABASE_URL="postgresql://postgres:password@host.railway.internal:5432/havilon_fleet"

# ── NextAuth ──────────────────────────────────
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="your-random-secret-here-at-least-32-chars"
NEXTAUTH_URL="https://havilon-fleet.vercel.app"
# For local dev: NEXTAUTH_URL="http://localhost:3000"

# ── Google OAuth (for login) ──────────────────
# Create at: console.cloud.google.com → APIs → Credentials → OAuth 2.0
# Authorized redirect URI: https://havilon-fleet.vercel.app/api/auth/callback/google
GOOGLE_CLIENT_ID="xxxx.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="GOCSPX-xxxx"

# ── Google Service Account (Drive + Gmail + Sheets) ──
# Create at: console.cloud.google.com → IAM → Service Accounts → Create
# Download JSON key, extract these values:
GOOGLE_CLIENT_EMAIL="havilon-fleet@your-project.iam.gserviceaccount.com"
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEvAIBADANBgkqhkiG9w0BAQEFAASC...\n-----END PRIVATE KEY-----\n"

# Google Drive: share your fleet photos folder with the service account email above
GOOGLE_DRIVE_ROOT_FOLDER_ID="1BxiMVs0XRA5nFMdKvBdBZjgmUUqptlbs"

# Gmail: the email address that sends alerts (must match service account domain)
GMAIL_FROM="fleet-alerts@havilon.com"

# Google Sheets: share your accounting spreadsheet with service account
GOOGLE_SHEETS_ID="1BxiMVs0XRA5nFMdKvBdBZjgmUUqptlbs74zmn"

# ── Access Control ─────────────────────────────
# Restrict login to your domain
ALLOWED_EMAIL_DOMAIN="havilon.com"
# Or allow specific emails (comma-separated, useful for contractors)
ALLOWED_EMAILS="vendor@example.com,auditor@firm.com"

GOOGLE_WORKSPACE_DOMAIN="havilon.com"

# ── App Config ────────────────────────────────
NODE_ENV="production"
