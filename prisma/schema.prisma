generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── ENUMS ───────────────────────────────────────────────────────────────────

enum UserRole {
  OWNER
  OPS_MANAGER
  MECHANIC
  ACCOUNTING
  AUDIT
}

enum VehicleStatus {
  ACTIVE
  GROUNDED
  IN_REPAIR
  DECOMMISSIONED
}

enum RepairStatus {
  PENDING_REVIEW
  AWAITING_ESTIMATE
  APPROVED
  IN_PROGRESS
  COMPLETED
  REJECTED
  DISPUTED
}

enum RepairCategory {
  TIRES
  BRAKES
  COLLISION
  ENGINE
  ELECTRICAL
  BODY
  SUSPENSION
  HVAC
  GLASS
  OTHER
}

enum FraudSeverity {
  CRITICAL
  WARNING
  INFO
}

enum ApprovalTier {
  TIER_1_STANDARD     // < $250 — ops manager only
  TIER_2_SECONDARY    // $250–$1000 — secondary approval
  TIER_3_OWNER        // $1000–$2500 — owner required
  TIER_4_EXECUTIVE    // > $2500 — full executive review
}

enum PartReturnStatus {
  NA
  PENDING_RETURN
  RETURNED
  KEPT
}

// ─── TABLES ──────────────────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String
  role          UserRole  @default(AUDIT)
  image         String?
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  lastLogin     DateTime?

  // relations
  repairsRequested  Repair[]        @relation("RequestedBy")
  repairsApproved   Repair[]        @relation("ApprovedBy")
  approvalEvents    ApprovalEvent[]
  notifications     Notification[]
  vehicleAssigned   Vehicle[]       @relation("AssignedDriver")
  partsOrdered      PartsOrder[]    @relation("OrderedBy")
  partsApproved     PartsOrder[]    @relation("ApprovedBy")
  fraudResolved     FraudEvent[]    @relation("ResolvedBy")
  referralCode      ReferralCode?
  payoutRequests    PayoutRequest[]

  accounts Account[]
  sessions Session[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model Vehicle {
  id                    String        @id @default(cuid())
  vin                   String        @unique
  vehicleNumber         String        @unique
  licensePlate          String?
  make                  String
  model                 String
  year                  Int
  odometerCurrent       Int           @default(0)
  odometerLastUpdated   DateTime?
  acquisitionDate       DateTime?
  status                VehicleStatus @default(ACTIVE)
  isGrounded            Boolean       @default(false)
  groundedReason        String?
  groundedAt            DateTime?
  estimatedValue        Float?
  totalLifetimeRepairCost Float       @default(0)
  totalDowntimeHours    Float         @default(0)
  accidentCount         Int           @default(0)
  lastInspectionDate    DateTime?
  notes                 String?
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt

  driverId              String?
  driver                User?         @relation("AssignedDriver", fields: [driverId], references: [id])

  repairs               Repair[]
  partsOrders           PartsOrder[]
  routeAssignments      RouteAssignment[]

  @@map("vehicles")
}

model RepairShop {
  id                  String    @id @default(cuid())
  name                String
  address             String?
  phone               String?
  contactPerson       String?
  email               String?
  categories          String[]
  avgRepairCost       Float     @default(0)
  avgCompletionHours  Float     @default(0)
  totalRepairs        Int       @default(0)
  repeatRepairRate    Float     @default(0)
  warrantyIssueCount  Int       @default(0)
  lifetimeSpend       Float     @default(0)
  fraudScore          Int       @default(0)
  fraudFlags          Json      @default("[]")
  isActive            Boolean   @default(true)
  isBlacklisted       Boolean   @default(false)
  notes               String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  repairs             Repair[]

  @@map("repair_shops")
}

model Repair {
  id                  String          @id @default(cuid())
  repairNumber        String          @unique
  status              RepairStatus    @default(PENDING_REVIEW)
  category            RepairCategory
  approvalTier        ApprovalTier?
  damageType          String?
  description         String
  requestDate         DateTime        @default(now())
  completionDate      DateTime?
  estimatedCost       Float?
  actualCost          Float?
  laborHours          Float?
  laborRate           Float?
  laborCost           Float?
  partsCost           Float?
  totalCost           Float?
  routeIncidentNumber String?
  insuranceClaimId    String?
  isWarranty          Boolean         @default(false)
  isRepeatRepair      Boolean         @default(false)
  repeatRepairRefId   String?

  // fraud intelligence
  fraudScore          Int             @default(0)
  fraudFlags          String[]        @default([])
  requiresOwnerApproval Boolean       @default(false)
  ownerApproved       Boolean         @default(false)

  // photo evidence (Google Drive URLs)
  photosBefore        String[]        @default([])
  photosDuring        String[]        @default([])
  photosAfter         String[]        @default([])
  photosWideAngle     String[]        @default([])
  photosCloseUp       String[]        @default([])

  // documents
  invoiceUrl          String?
  invoiceHash         String?         // for duplicate detection
  estimate1Url        String?
  estimate2Url        String?
  driveFolderId       String?         // Google Drive folder ID

  // relations
  vehicleId           String
  vehicle             Vehicle         @relation(fields: [vehicleId], references: [id])
  shopId              String?
  shop                RepairShop?     @relation(fields: [shopId], references: [id])
  requestedById       String?
  requestedBy         User?           @relation("RequestedBy", fields: [requestedById], references: [id])
  approvedById        String?
  approvedBy          User?           @relation("ApprovedBy", fields: [approvedById], references: [id])
  driverId            String?

  approvalEvents      ApprovalEvent[]
  fraudEvents         FraudEvent[]
  partsOrders         PartsOrder[]
  notifications       Notification[]

  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt

  @@map("repairs")
}

// Immutable audit trail — no updates, only inserts
model ApprovalEvent {
  id            String        @id @default(cuid())
  repairId      String
  repair        Repair        @relation(fields: [repairId], references: [id])
  action        String        // approved | rejected | escalated | flagged | requested_info
  actorId       String
  actor         User          @relation(fields: [actorId], references: [id])
  approvalTier  ApprovalTier?
  reason        String?
  notes         String?
  createdAt     DateTime      @default(now())

  @@map("approval_events")
}

model PartsOrder {
  id                  String            @id @default(cuid())
  orderNumber         String            @unique
  partName            String
  partNumber          String?
  quantity            Int               @default(1)
  unitCost            Float
  totalCost           Float
  vendor              String
  amazonOrderNumber   String?
  dateOrdered         DateTime
  dateDelivered       DateTime?
  installedBy         String?
  installedDate       DateTime?
  returnStatus        PartReturnStatus  @default(NA)
  warrantyStatus      String?
  invoiceUrl          String?
  isDuplicateFlag     Boolean           @default(false)
  duplicateRefId      String?
  notes               String?
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt

  vehicleId           String
  vehicle             Vehicle           @relation(fields: [vehicleId], references: [id])
  repairId            String?
  repair              Repair?           @relation(fields: [repairId], references: [id])
  orderedById         String?
  orderedBy           User?             @relation("OrderedBy", fields: [orderedById], references: [id])
  approvedById        String?
  approvedBy          User?             @relation("ApprovedBy", fields: [approvedById], references: [id])

  @@map("parts_orders")
}

model FraudEvent {
  id            String        @id @default(cuid())
  entityType    String        // repair | shop | parts | vehicle
  entityId      String
  flagType      String
  severity      FraudSeverity
  description   String
  riskScore     Int
  isActive      Boolean       @default(true)
  detectedAt    DateTime      @default(now())
  resolvedAt    DateTime?
  resolvedById  String?
  resolvedBy    User?         @relation("ResolvedBy", fields: [resolvedById], references: [id])
  resolutionNotes String?

  repairId      String?
  repair        Repair?       @relation(fields: [repairId], references: [id])

  @@map("fraud_events")
}

model Notification {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id])
  type        String
  title       String
  body        String
  entityId    String?
  entityType  String?
  channel     String    @default("in_app") // email | in_app | both
  sentAt      DateTime  @default(now())
  readAt      DateTime?
  isResolved  Boolean   @default(false)

  repairId    String?
  repair      Repair?   @relation(fields: [repairId], references: [id])

  @@map("notifications")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ─── DA ROSTER & AMAZON SYNC TABLES ──────────────────────────────────────────

enum DAStatus {
  ACTIVE
  INACTIVE
  ON_LEAVE
  TERMINATED
}

enum AlertSeverity {
  INFO
  WARNING
  CRITICAL
}

model DA {
  id              String    @id @default(cuid())
  name            String
  email           String?   @unique
  phone           String?
  status          DAStatus  @default(ACTIVE)
  adpId           String?
  badgeId         String?
  transponderId   String?
  amazonRouteId   String?
  voxerId         String?
  driverLicense   String?
  dlExpiry        DateTime?
  dateOfBirth     DateTime?
  zipCode         String?
  hireDate        DateTime?
  terminationDate DateTime?
  offDays         String[]  @default([])
  emergencyName   String?
  emergencyPhone  String?
  uniformPants    Boolean   @default(false)
  uniformShorts   Boolean   @default(false)
  uniformVest     Boolean   @default(false)
  uniformShirtSize String?
  phoneImei       String?
  phoneAssigned   Boolean   @default(false)
  equipmentNotes  String?
  hasHealthInsurance Boolean @default(false)
  gasPin          String?
  notes           String?
  scorecards      DAScorecard[]
  alerts          DAAlert[]
  routeAssignments RouteAssignment[]
  disciplineLog   DisciplineRecord[]
  timeOffRequests TimeOffRequest[]
  documents       EmployeeDocument[]
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@map("das")
}

model DAScorecard {
  id              String    @id @default(cuid())
  daId            String
  da              DA        @relation(fields: [daId], references: [id])
  week            String
  amazonDaId      String?
  deliveryScore   Float     @default(0)
  qualityScore    Float     @default(0)
  safetyScore     Float     @default(0)
  dnrRate         Float     @default(0)
  dsbRate         Float     @default(0)
  standing        String    @default("GOOD")
  syncedAt        DateTime  @default(now())
  createdAt       DateTime  @default(now())

  @@unique([daId, week])
  @@map("da_scorecards")
}

model DAAlert {
  id          String        @id @default(cuid())
  daId        String
  da          DA            @relation(fields: [daId], references: [id])
  week        String
  type        String
  severity    AlertSeverity @default(WARNING)
  details     String
  isResolved  Boolean       @default(false)
  resolvedAt  DateTime?
  createdAt   DateTime      @default(now())

  @@unique([daId, week, type])
  @@map("da_alerts")
}

model RouteAssignment {
  id            String    @id @default(cuid())
  date          String
  routeCode     String
  routeType     String    @default("BASE")
  daId          String?
  da            DA?       @relation(fields: [daId], references: [id])
  vehicleId     String?
  vehicle       Vehicle?  @relation(fields: [vehicleId], references: [id])
  stopCount     Int?
  packageVolume Int?
  destination   String?
  stageLocation String?
  departureTime String?
  status        String    @default("SCHEDULED")
  amazonDaId    String?
  phoneNumber   String?
  phoneImei     String?
  syncedAt      DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@unique([date, routeCode])
  @@map("route_assignments")
}

model DisciplineRecord {
  id          String    @id @default(cuid())
  daId        String
  da          DA        @relation(fields: [daId], references: [id])
  date        DateTime
  type        String
  description String
  issuedBy    String
  documentUrl String?
  createdAt   DateTime  @default(now())

  @@map("discipline_records")
}

model PhoneAssignment {
  id          String    @id @default(cuid())
  date        String
  phoneImei   String
  phoneNumber String?
  daName      String
  daId        String?
  routeCode   String?
  condition   String?
  notes       String?
  returnedAt  DateTime?
  createdAt   DateTime  @default(now())

  @@map("phone_assignments")
}

model SyncLog {
  id      String    @id @default(cuid())
  type    String
  status  String
  result  Json?
  runAt   DateTime  @default(now())

  @@map("sync_logs")
}

model Incident {
  id              String    @id @default(cuid())
  incidentNumber  String    @unique
  date            DateTime
  type            String
  description     String
  daId            String?
  vehicleId       String?
  reportedBy      String?
  policeReport    String?
  insuranceClaim  String?
  status          String    @default("OPEN")
  documentUrls    String[]  @default([])
  notes           String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@map("incidents")
}

// ─── EMPLOYEE RECOGNITION ─────────────────────────────────────────────────────

model EmployeeAward {
  id              String    @id @default(cuid())
  type            String    // WEEK | MONTH | QUARTER | YEAR
  period          String    // "2026-W20" | "May 2026" | "Q2 2026" | "2026"
  winnerId        String
  winnerName      String
  winnerScore     Float
  runnerUpName    String?
  runnerUpScore   Float?
  thirdPlaceName  String?
  thirdPlaceScore Float?
  scoreBreakdown  Json?     // Top 10 full scores for that period
  calculatedAt    DateTime  @default(now())
  announcedAt     DateTime?

  @@unique([type, period])
  @@map("employee_awards")
}

// ─── OVERTIME & PERFORMANCE RISK TABLES ──────────────────────────────────────

model DAHoursLog {
  id                    String    @id @default(cuid())
  daId                  String
  week                  String
  weeklyHoursWorked     Float     @default(0)
  weeklyHoursScheduled  Float     @default(0)
  projectedWeeklyHours  Float     @default(0)
  overtimeHours         Float     @default(0)
  status                String    @default("NORMAL") // NORMAL | WARNING | OVERTIME | CRITICAL
  dailyHours            Json      @default("{}")
  lastUpdated           DateTime  @default(now())

  @@unique([daId, week])
  @@map("da_hours_log")
}

model DAPerformanceFlag {
  id                    String    @id @default(cuid())
  daId                  String    @unique
  riskLevel             String    // WATCH | WARNING | NOT_RECOMMENDED | FURLOUGH
  consecutivePoorWeeks  Int       @default(0)
  avgDeliveryScore      Float     @default(0)
  avgQualityScore       Float     @default(0)
  avgSafetyScore        Float     @default(0)
  trend                 String    @default("FLAT") // IMPROVING | DECLINING | FLAT
  trendDelta            Float     @default(0)
  primaryConcern        String
  recommendation        String
  safetyRisk            Boolean   @default(false)
  isResolved            Boolean   @default(false)
  resolvedAt            DateTime?
  resolvedNote          String?
  lastAssessed          DateTime  @default(now())
  createdAt             DateTime  @default(now())

  @@map("da_performance_flags")
}

// ─── TIME OFF & LEAVE MANAGEMENT ─────────────────────────────────────────────

enum TimeOffType {
  VACATION
  PERSONAL
  MEDICAL_EMERGENCY
  BEREAVEMENT
  OTHER
}

enum TimeOffStatus {
  PENDING
  APPROVED
  DENIED
  CANCELLED
  PENDING_MEDICAL_CLEARANCE  // Approved but needs Dr note before returning
}

model TimeOffRequest {
  id              String        @id @default(cuid())
  requestNumber   String        @unique
  daId            String
  da              DA            @relation(fields: [daId], references: [id])

  type            TimeOffType
  status          TimeOffStatus @default(PENDING)

  startDate       DateTime
  endDate         DateTime
  totalDays       Int

  reason          String?
  isEmergency     Boolean       @default(false)

  // Medical emergency fields
  requiresDrNote  Boolean       @default(false)
  drNoteReceived  Boolean       @default(false)
  drNoteUrl       String?       // Google Drive link
  drNoteReceivedAt DateTime?
  returnToWorkCleared Boolean   @default(false)

  // Review
  reviewedBy      String?
  reviewedAt      DateTime?
  reviewNotes     String?

  // Notifications
  submittedAt     DateTime      @default(now())
  notifiedAt      DateTime?

  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@map("time_off_requests")
}

// ─── ANONYMOUS TIPS ───────────────────────────────────────────────────────────

model AnonymousTip {
  id          String   @id @default(cuid())
  tipNumber   String   @unique
  category    String   // SAFETY | CONDUCT | OPERATIONS | FRAUD | OTHER
  message     String
  isRead      Boolean  @default(false)
  isActedOn   Boolean  @default(false)
  actionNotes String?
  createdAt   DateTime @default(now())

  @@map("anonymous_tips")
}

// ─── EMPLOYEE SENTIMENT SURVEYS ───────────────────────────────────────────────

model SentimentSurvey {
  id          String           @id @default(cuid())
  title       String
  period      String           // e.g. "May 2026"
  isActive    Boolean          @default(true)
  closedAt    DateTime?
  responses   SurveyResponse[]
  createdAt   DateTime         @default(now())

  @@map("sentiment_surveys")
}

model SurveyResponse {
  id        String          @id @default(cuid())
  surveyId  String
  survey    SentimentSurvey @relation(fields: [surveyId], references: [id])

  // Scores 1-5 for each dimension
  overallSatisfaction  Int
  managementRating     Int
  workloadRating       Int
  safetyRating         Int
  communicationRating  Int
  wouldRecommend       Boolean
  openFeedback         String?

  // Anonymous — no DA ID stored
  submittedAt DateTime @default(now())

  @@map("survey_responses")
}

// ─── DOCUMENT SIGNING TRACKER ────────────────────────────────────────────────

model EmployeeDocument {
  id           String    @id @default(cuid())
  daId         String
  da           DA        @relation(fields: [daId], references: [id])
  docType      String    // BACKGROUND_CHECK | AMAZON_CONSENT | DRUG_TEST | OFFER_LETTER | HANDBOOK
  signed       Boolean   @default(false)
  signedAt     DateTime?
  documentUrl  String?
  notes        String?
  createdAt    DateTime  @default(now())

  @@unique([daId, docType])
  @@map("employee_documents")
}

// ─── INSURANCE REFERRAL ───────────────────────────────────────────────────────

model InsuranceReferral {
  id              String   @id @default(cuid())
  referralNumber  String   @unique

  // Who is asking
  daId            String?
  daName          String
  email           String
  phone           String?

  // What they need quoted
  insuranceTypes  String[] // AUTO | LIFE | HEALTH | RENTERS | HOME | UMBRELLA

  // Auto details
  vehicleVin      String?
  vehicleYear     String?
  vehicleMake     String?
  vehicleModel    String?
  currentCarrier  String?
  currentRate     String?

  // Other details
  additionalNotes String?
  referralCode    String?            // The code used to refer
  referralCodeId  String?
  codeRef         ReferralCode? @relation("ReferralCodeToReferral", fields: [referralCodeId], references: [id])

  // Status
  bonusAmount     Float    @default(0)
  bonusEligibleAt DateTime?  // 30 days after bind date
  bonusPaid       Boolean  @default(false)
  bindDate        DateTime?
  status          String   @default("NEW") // NEW | QUOTED | CONVERTED | DECLINED
  quotedAt        DateTime?
  quotedRate      String?
  agentNotes      String?

  createdAt       DateTime @default(now())

  @@map("insurance_referrals")
}

// ─── INSURANCE REFERRAL PROGRAM ───────────────────────────────────────────────

model ReferralCode {
  id          String   @id @default(cuid())
  code        String   @unique   // e.g. "MARCUS-X7K2"
  userId      String   @unique   // Staff or DA user ID
  daId        String?            // If a DA
  name        String             // Display name
  isActive    Boolean  @default(true)
  totalEarned Float    @default(0)
  totalPaid   Float    @default(0)
  balance     Float    @default(0)
  user        User     @relation(fields: [userId], references: [id])
  referrals   InsuranceReferral[] @relation("ReferralCodeToReferral")
  submissions Referral[]
  payouts     ReferralPayout[]
  createdAt   DateTime @default(now())

  @@map("referral_codes")
}

model ReferralPayout {
  id             String       @id @default(cuid())
  referralCodeId String
  referralCode   ReferralCode @relation(fields: [referralCodeId], references: [id])
  amount         Float
  status         String       @default("REQUESTED") // REQUESTED | APPROVED | PAID | DENIED
  requestedAt    DateTime     @default(now())
  processedAt    DateTime?
  processedBy    String?
  paymentMethod  String?
  notes          String?

  @@map("referral_payouts")
}

model Referral {
  id              String       @id @default(cuid())
  referralNumber  String       @unique
  codeId          String
  code            ReferralCode @relation(fields: [codeId], references: [id])

  // The referred person
  refereeName     String
  refereeEmail    String
  refereePhone    String?
  insuranceTypes  String[]

  // Quote details
  vehicleVin      String?
  vehicleYear     String?
  vehicleMake     String?
  vehicleModel    String?
  currentCarrier  String?
  currentRate     String?
  additionalNotes String?

  // Status tracking
  status          String    @default("SUBMITTED")
  // SUBMITTED → QUOTED → BOUND → ACTIVE (30 days) → BONUS_ELIGIBLE → PAID

  quotedAt        DateTime?
  boundAt         DateTime?
  activeSince     DateTime?   // When policy went active
  bonusEligibleAt DateTime?   // boundAt + 30 days
  bonusAmount     Float?      @default(0)
  bonusPaidAt     DateTime?
  agentNotes      String?

  createdAt       DateTime  @default(now())

  @@map("referrals")
}

model PayoutRequest {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  amount      Float
  method      String   @default("ADP") // ADP | ZELLE | CHECK
  status      String   @default("PENDING") // PENDING | APPROVED | PAID | DENIED
  notes       String?
  processedAt DateTime?
  createdAt   DateTime @default(now())

  @@map("payout_requests")
}
